<script>
  function getCurrentLocation() {
    const langAttr = document.querySelector('html').getAttribute('lang')
    return langAttr ? langAttr : 'pt-BR'
  }

  const LITERALS = {
    'en': {
      homeAnimationTexts: [
        "Lawsuit Answers",
        "Mapping Predatory Litigation",
        "Identifying Document Fraud",
        "Verifying free access to court", 
        "Appeals",
        "Special Appeals",
        "Answers to Regulatory Agencies", 
      ],
      clients: 'Clients',
      security: 'Security', 
      company: 'Company',
      news: 'News',
      termsAndConditions: 'Terms and Conditions',
      privacyPolicy: 'Privacy Policy',
      ombudsman: 'Ombudsman',
      litigation: 'Litigation' 
    },
    'pt-BR': {
      homeAnimationTexts: [
        "Contestações",
        "Mapear Litigância Predatória",
        "Identificar Fraude Documental",
        "Conferir Gratuidade de Justiça", 
        "Apelações",
        "Recursos Inominados",
      ],
      clients: 'Clientes',
      security: 'Segurança', 
      company: 'Empresa',
      news: 'Notícias',
      termsAndConditions: 'Termos e Condições',
      privacyPolicy: 'Política de Privacidade',
      ombudsman: 'Ouvidoria',
      litigation: 'Contencioso'
    }
  }
  
  function getLiteralByLocation(word) {
    const currentLocation = getCurrentLocation();
    return LITERALS[currentLocation][word]
  }
</script>

<!-- Menu Mobile lock scroll-->
<script>
  // Number of clicks on the trigger element initially set on 0
let numOfClicks = 0;
// Get trigger element 
const trigger = document.getElementById("menu-scroll");
// Get body element
const bodyEl = document.getElementsByTagName("body")[0];

// Set onclick function to trigger element
trigger.onclick = () => {
    numOfClicks += 1;
    // Check if number of clicks is an even value: 
    // odd value - first click, even value - second click
    const isNumOfClicksEven = numOfClicks % 2 === 0;
    // On first click set body's overflow property to "auto", 
    // On second click set body's overflow property to "hidden"
    isNumOfClicksEven ? bodyEl.style.overflow = "auto" : bodyEl.style.overflow = "hidden";
};
</script>  


<!---- Desabilitar Scroll ----> 

<script>
  // Função para desabilitar o scroll
  function disableScroll() {
    document.body.style.overflow = 'hidden';
  }

  // Função para habilitar o scroll
  function enableScroll() {
    document.body.style.overflow = 'auto';
  }

  // Exemplo de uso com um menu
  const menu = document.querySelector('#contact-form'); // Substitua '.menu' pelo seletor do seu menu
  const menuTrigger = document.querySelector('#gsap-box'); // Substitua '.menu-trigger' pelo seletor do botão que abre o menu
  const closeButton = document.querySelector('#form-button-close');

  if (menuTrigger && menu) {
    menuTrigger.addEventListener('click', () => {
      const isMenuVisible = menu.classList.contains('is-visible'); // Substitua 'is-visible' pela classe que indica que seu menu está visível

      if (isMenuVisible) {
        enableScroll();
      } else {
        disableScroll();
      }
    });
  }

  // Observador de mutação para detectar mudanças na visibilidade do menu
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
        const isVisible = menu.classList.contains('is-visible'); // Substitua 'is-visible' pela classe que indica que seu menu está visível
        if (isVisible) {
          disableScroll();
        } else {
          enableScroll();
        }
      }
    });
  });

  if (menu) {
    observer.observe(menu, {
      attributes: true
    });
  }

  // Fechar menu quando clicar fora dele
  document.addEventListener('click', (event) => {
    if (menu && menu.classList.contains('is-visible')) {
      // Verifica se o clique foi fora do menu e do botão que abre o menu
      if (!menu.contains(event.target) && !menuTrigger.contains(event.target)) {
        menu.classList.remove('is-visible');
        enableScroll();
      }
    }
  });

  // Fechar menu ao pressionar ESC
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && menu && menu.classList.contains('is-visible')) {
      menu.classList.remove('is-visible');
      enableScroll();
    }
  });

  closeButton.addEventListener('click', (event) => {
    menu.classList.remove('is-visible');
    enableScroll();
  })
</script><script src="https://cdn.prod.website-files.com/67b30e3c33bea6276dc0a7b6%2F6703da09f91e18499e9791c5%2F69175def2e0f329ce27b10bb%2Fwebflowembed67b30e3c33bea6276dc0a7b65523-3.0.0.js" type="text/javascript"></script></body></html>