# Gateway unificado da plataforma do Grupo 9
#
# Acesso externo: http://localhost:8080
# Rotas:
#   /                    -> frontend React (build estático em frontend/dist/)
#   /api/*               -> backend Flask (localhost:5000)
#   /monitoramento/*     -> dashboard Streamlit (localhost:8501)
#
# Para desenvolvimento (com hot-reload do Vite), descomente o bloco
# "dev mode" e comente o handle "/".

:8080 {
    # ── Backend Flask ─────────────────────────────────────────────────────────
    handle /api/* {
        reverse_proxy localhost:5000
    }

    # ── Dashboard Streamlit (com WebSocket para reatividade) ───────────────────
    handle /monitoramento/* {
        reverse_proxy localhost:8501
    }

    # ── Frontend React (produção: build estático) ─────────────────────────────
    handle {
        root * frontend/dist
        try_files {path} /index.html
        file_server
    }

    # ── Dev mode (hot-reload) — descomente e comente o handle "/" acima ───────
    # handle {
    #     reverse_proxy localhost:5173
    # }

    # Logs
    log {
        output file ./logs/caddy.log
        format console
    }
}
